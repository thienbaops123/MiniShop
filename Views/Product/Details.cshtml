@model MiniShop.Models.Product
@{
    ViewData["Title"] = "Product Details";
    var img = string.IsNullOrWhiteSpace(Model.ImageUrl)
        ? "https://placehold.co/900x600?text=MiniShop"
        : Model.ImageUrl;
}

<div class="row g-4">
    <div class="col-12 col-lg-5">
        <div class="border rounded p-3 bg-light">
            <img src="@img" style="width:100%; height:320px; object-fit:contain;" alt="@Model.Name" />
        </div>
    </div>

    <div class="col-12 col-lg-7">
        <h2 class="mb-1">@Model.Name</h2>
        <p class="text-muted mb-2">Category: @Model.Category?.Name</p>

        <div class="h4 text-success mb-3">@Model.Price.ToString("N0") đ</div>

        <form class="row g-2" asp-controller="Cart" asp-action="Add" method="post">
            <input type="hidden" name="productId" value="@Model.Id" />
            <div class="col-4 col-md-3">
                <input class="form-control" type="number" name="quantity" value="1" min="1" />
            </div>
            <div class="col-8 col-md-5">
                <button class="btn btn-primary w-100" type="submit">
                    <i class="bi bi-cart-plus me-1"></i> Add to cart
                </button>
            </div>
        </form>

        <div class="mt-3">
            <a class="btn btn-link px-0" asp-action="Index">← Back to Products</a>
        </div>
    </div>
</div>