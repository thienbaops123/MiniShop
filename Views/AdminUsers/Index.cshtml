@model List<MiniShop.Models.User>
@using MiniShop.Models

@{
    ViewData["Title"] = "Manage Users";
    string StatusBadge(UserStatus s) => s switch
    {
        UserStatus.Active => "text-bg-success",
        UserStatus.Banned => "text-bg-danger",
        UserStatus.Suspended => "text-bg-warning",
        _ => "text-bg-secondary"
    };
}

<h2 class="mb-3">Manage Users</h2>

@if (TempData["Error"] is string e)
{
    <div class="alert alert-danger">@e</div>
}
@if (TempData["Success"] is string s)
{
    <div class="alert alert-success">@s</div>
}

<div class="d-flex flex-wrap gap-2 justify-content-between align-items-end mb-3">
    <form method="get" class="d-flex gap-2">
        <input name="q" class="form-control" value="@(ViewBag.Q ?? "")" placeholder="Search email/fullname..." />
        <button class="btn btn-outline-secondary">Search</button>
    </form>

    <a class="btn btn-primary" asp-action="Create">Create user</a>
</div>

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th style="width:70px;">Id</th>
                <th>Email</th>
                <th>FullName</th>
                <th style="width:90px;">Role</th>
                <th style="width:130px;">Status</th>
                <th style="width:240px;"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var u in Model)
            {
                <tr>
                    <td>@u.Id</td>
                    <td><code>@u.Email</code></td>
                    <td>@u.FullName</td>
                    <td>@u.Role</td>
                    <td>
                        <span class="badge @StatusBadge(u.Status)">@u.Status</span>
                    </td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@u.Id">Edit</a>

                        @if (u.Status == UserStatus.Banned)
                        {
                            <form method="post" asp-action="Unban" asp-route-id="@u.Id" class="d-inline">
                                <button class="btn btn-sm btn-outline-success">Unban</button>
                            </form>
                        }
                        else
                        {
                            <form method="post" asp-action="Ban" asp-route-id="@u.Id" class="d-inline">
                                <input type="hidden" name="reason" value="Banned by admin" />
                                <button class="btn btn-sm btn-outline-danger">Ban</button>
                            </form>
                        }

                        <form method="post" asp-action="Delete" asp-route-id="@u.Id" class="d-inline"
                              onsubmit="return confirm('Delete this user?');">
                            <button class="btn btn-sm btn-danger">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>