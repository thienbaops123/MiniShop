@model List<MiniShop.Models.Order>

@{
    ViewData["Title"] = "My Orders";
}

<div class="d-flex flex-wrap align-items-end justify-content-between gap-2 mb-3">
    <div>
        <h2 class="mb-1">My Orders</h2>
        <div class="text-muted small">Track your purchases and order status.</div>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-light border">
        <div class="fw-semibold mb-1">No orders yet</div>
        <div class="text-muted small">When you place an order, it will show up here.</div>
        <div class="mt-3">
            <a class="btn btn-primary" asp-controller="Product" asp-action="Index">Start shopping</a>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width:90px;">Id</th>
                        <th style="width:180px;">Created</th>
                        <th style="width:160px;">Status</th>
                        <th class="text-end" style="width:160px;">Total</th>
                        <th class="text-end" style="width:120px;"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var o in Model)
                    {
                        var badge = o.Status switch
                        {
                            MiniShop.Models.OrderStatus.Pending => "text-bg-warning",
                            MiniShop.Models.OrderStatus.Processing => "text-bg-info",
                            MiniShop.Models.OrderStatus.Paid => "text-bg-success",
                            _ => "text-bg-secondary"
                        };

                        <tr>
                            <td class="text-muted">#@o.Id</td>
                            <td class="text-muted">@o.CreatedDate.ToString("yyyy-MM-dd HH:mm")</td>
                            <td><span class="badge @badge">@o.Status</span></td>
                            <td class="text-end fw-semibold">@o.TotalAmount.ToString("N0") đ</td>
                            <td class="text-end">
                                <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@o.Id">
                                    Details
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}