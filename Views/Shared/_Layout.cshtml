@{
    var fullName = Context.Session.GetString("FullName");
    var email = Context.Session.GetString("Email");
    var role = Context.Session.GetString("Role") ?? "User";
    bool isLoggedIn = !string.IsNullOrWhiteSpace(email);
    bool isAdmin = string.Equals(role, "Admin", StringComparison.OrdinalIgnoreCase);

    string displayName = !string.IsNullOrWhiteSpace(fullName) ? fullName : (email ?? "Guest");
    string initial = string.IsNullOrWhiteSpace(displayName) ? "U" : displayName.Trim()[0].ToString().ToUpper();

    string? controller = ViewContext.RouteData.Values["controller"]?.ToString();
    string isActive(string c) => string.Equals(controller, c, StringComparison.OrdinalIgnoreCase) ? "active" : "";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MiniShop</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/theme.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container">
            <a class="navbar-brand" asp-controller="Product" asp-action="Index">MiniShop</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="nav">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link @isActive("Product")" asp-controller="Product" asp-action="Index">Products</a>
                    </li>

                    @if (isAdmin)
                    {
                        <li class="nav-item">
                            <a class="nav-link @isActive("Admin")" asp-controller="Admin" asp-action="Products">
                                Admin Products
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link @isActive("AdminUsers")" asp-controller="AdminUsers" asp-action="Index">
                                Users
                            </a>
                        </li>
                    }
                </ul>

                <ul class="navbar-nav ms-auto align-items-center gap-2">
                    @if (!isLoggedIn)
                    {
                        <li class="nav-item">
                            <a class="btn btn-outline-light btn-sm" asp-controller="Account" asp-action="Login">Login</a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-primary btn-sm" asp-controller="Account" asp-action="Register">Register</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link position-relative" asp-controller="Cart" asp-action="Index" title="Cart">
                                <i class="bi bi-cart3" style="font-size: 1.2rem;"></i>
                            </a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle d-flex align-items-center gap-2"
                               href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <span class="rounded-circle bg-secondary text-white d-inline-flex align-items-center justify-content-center"
                                      style="width:34px;height:34px;font-weight:700;">
                                    @initial
                                </span>
                                <span class="d-none d-lg-inline">@displayName</span>
                            </a>

                            <ul class="dropdown-menu dropdown-menu-end shadow" style="min-width: 280px;">
                                <li class="px-3 py-2">
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="rounded-circle bg-secondary text-white d-inline-flex align-items-center justify-content-center"
                                              style="width:44px;height:44px;font-weight:700;">
                                            @initial
                                        </span>
                                        <div>
                                            <div class="fw-semibold">@displayName</div>
                                            <div class="small text-muted">@role</div>
                                        </div>
                                    </div>
                                </li>

                                <li><hr class="dropdown-divider" /></li>

                                <li>
                                    <a class="dropdown-item" asp-controller="Account" asp-action="Profile">
                                        View my profile
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Account" asp-action="ChangePassword">
                                        Account settings
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Order" asp-action="MyOrders">
                                        Order history
                                    </a>
                                </li>

                                @if (isAdmin)
                                {
                                    <li><hr class="dropdown-divider" /></li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Admin" asp-action="Products">
                                            Manage products
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="AdminUsers" asp-action="Index">
                                            Manage users
                                        </a>
                                    </li>
                                }

                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <a class="dropdown-item text-danger" asp-controller="Account" asp-action="Logout">
                                        Logout
                                    </a>
                                </li>
                            </ul>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link position-relative" asp-controller="Cart" asp-action="Index" title="Cart">
                                <i class="bi bi-cart3" style="font-size: 1.2rem;"></i>
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <div class="page-wrap">
        <main class="container py-4">
            @RenderBody()
        </main>
    </div>

    <footer class="py-4">
        <div class="container footer small">
            © @DateTime.Now.Year MiniShop — All rights reserved.
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>