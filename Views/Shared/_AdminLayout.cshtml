@{
    Layout = null;

    var fullName = Context.Session.GetString("FullName");
    var email = Context.Session.GetString("Email");
    var role = Context.Session.GetString("Role") ?? "User";
    bool isLoggedIn = !string.IsNullOrWhiteSpace(email);
    bool isAdmin = string.Equals(role, "Admin", StringComparison.OrdinalIgnoreCase);

    string displayName = !string.IsNullOrWhiteSpace(fullName) ? fullName : (email ?? "Guest");
    string initial = string.IsNullOrWhiteSpace(displayName) ? "U" : displayName.Trim()[0].ToString().ToUpper();

    string? action = ViewContext.RouteData.Values["action"]?.ToString();
    string active(string a) => string.Equals(action, a, StringComparison.OrdinalIgnoreCase) ? "active" : "";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin - MiniShop</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body class="admin-body">
    <div class="admin-shell">
        <aside class="admin-sidebar">
            <div class="admin-brand">
                <div class="admin-logo">MS</div>
                <div>
                    <div class="fw-bold">MiniShop</div>
                    <div class="small text-muted">Admin</div>
                </div>
            </div>

            <nav class="admin-nav">
                <a class="admin-link @active("Products")" asp-controller="Admin" asp-action="Products">
                    <i class="bi bi-box-seam"></i>
                    <span>Products</span>
                </a>

                <a class="admin-link @active("Orders")" asp-controller="Admin" asp-action="Orders">
                    <i class="bi bi-receipt"></i>
                    <span>Orders</span>
                </a>

                <div class="admin-nav-sep"></div>

                <a class="admin-link" asp-controller="Product" asp-action="Index">
                    <i class="bi bi-shop"></i>
                    <span>Back to shop</span>
                </a>
            </nav>

            <div class="admin-side-footer">
                <div class="d-flex align-items-center gap-2">
                    <div class="admin-avatar">@initial</div>
                    <div class="min-w-0">
                        <div class="fw-semibold text-truncate">@displayName</div>
                        <div class="small text-muted">@role</div>
                    </div>
                </div>

                <div class="d-flex gap-2 mt-3">
                    <a class="btn btn-sm btn-outline-secondary w-100" asp-controller="Account" asp-action="Profile">
                        Profile
                    </a>
                    <a class="btn btn-sm btn-outline-danger w-100" asp-controller="Account" asp-action="Logout">
                        Logout
                    </a>
                </div>
            </div>
        </aside>

        <div class="admin-main">
            <header class="admin-topbar">
                <button class="btn btn-sm btn-outline-secondary d-lg-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#adminOffcanvas">
                    <i class="bi bi-list"></i>
                </button>

                <div class="admin-top-title">
                    <div class="fw-semibold">@ViewData["Title"]</div>
                    <div class="small text-muted">@DateTime.Now.ToString("yyyy-MM-dd HH:mm")</div>
                </div>

                <div class="ms-auto d-flex align-items-center gap-2">
                    <span class="badge text-bg-light border">Admin</span>
                </div>
            </header>

            <main class="admin-content">
                @RenderBody()
            </main>

            <footer class="admin-footer small text-muted">
                © @DateTime.Now.Year MiniShop — Admin
            </footer>
        </div>
    </div>

    <!-- Mobile offcanvas sidebar -->
    <div class="offcanvas offcanvas-start d-lg-none" tabindex="-1" id="adminOffcanvas">
        <div class="offcanvas-header">
            <h5 class="offcanvas-title">MiniShop Admin</h5>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
        </div>
        <div class="offcanvas-body">
            <div class="d-flex align-items-center gap-2 mb-3">
                <div class="admin-avatar">@initial</div>
                <div>
                    <div class="fw-semibold">@displayName</div>
                    <div class="small text-muted">@role</div>
                </div>
            </div>

            <div class="list-group">
                <a class="list-group-item list-group-item-action" asp-controller="Admin" asp-action="Products">
                    <i class="bi bi-box-seam me-2"></i> Products
                </a>
                <a class="list-group-item list-group-item-action" asp-controller="Admin" asp-action="Orders">
                    <i class="bi bi-receipt me-2"></i> Orders
                </a>
                <a class="list-group-item list-group-item-action" asp-controller="Product" asp-action="Index">
                    <i class="bi bi-shop me-2"></i> Back to shop
                </a>
            </div>

            <div class="d-flex gap-2 mt-3">
                <a class="btn btn-sm btn-outline-secondary w-100" asp-controller="Account" asp-action="Profile">Profile</a>
                <a class="btn btn-sm btn-outline-danger w-100" asp-controller="Account" asp-action="Logout">Logout</a>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>