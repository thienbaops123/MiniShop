@model List<MiniShop.Models.Order>
@using MiniShop.Models

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Orders";

    // Keep current view state (safe variables)
    var q = ViewBag.Q as string;
    OrderStatus? status = ViewBag.Status as OrderStatus?;
    int currentPage = ViewBag.Page is int p ? p : 1;
}

<div class="admin-card p-3 p-lg-4">
    <div class="d-flex flex-wrap gap-2 align-items-center justify-content-between mb-3">
        <div>
            <div class="h5 mb-1">Manage orders</div>
            <div class="text-muted small">Update order status and view details.</div>
        </div>

        <a class="btn btn-outline-secondary" asp-action="Products">
            <i class="bi bi-box-seam me-1"></i> Products
        </a>
    </div>

    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th style="width:100px;">Id</th>
                    <th style="width:160px;">Created</th>
                    <th>User</th>
                    <th style="width:160px;">Status</th>
                    <th style="width:160px;" class="text-end">Total</th>
                    <th style="width:260px;">Update</th>
                    <th style="width:120px;" class="text-end"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var o in Model)
                {
                    <tr>
                        <td class="text-muted">#@o.Id</td>
                        <td class="text-muted">@o.CreatedDate.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>
                            <div class="fw-semibold">User #@o.UserId</div>
                            <div class="small text-muted">@o.User?.Email</div>
                        </td>
                        <td>
                            @{
                                var badge = o.Status switch
                                {
                                    OrderStatus.Pending => "text-bg-warning",
                                    OrderStatus.Processing => "text-bg-info",
                                    OrderStatus.Paid => "text-bg-success",
                                    _ => "text-bg-secondary"
                                };
                            }
                            <span class="badge @badge">@o.Status</span>
                        </td>
                        <td class="text-end fw-semibold">@o.TotalAmount.ToString("0.##") đ</td>
                        <td>
                            <form asp-action="UpdateOrderStatus" method="post" class="d-flex gap-2">
                                <!-- keep state -->
                                <input type="hidden" name="page" value="@currentPage" />
                                <input type="hidden" name="q" value="@q" />
                                <input type="hidden" name="filterStatus" value="@status" />

                                <!-- action data -->
                                <input type="hidden" name="id" value="@o.Id" />

                                <select class="form-select form-select-sm" name="status">
                                    <option value="@OrderStatus.Pending" selected="@(o.Status == OrderStatus.Pending)">Pending</option>
                                    <option value="@OrderStatus.Processing" selected="@(o.Status == OrderStatus.Processing)">Processing</option>
                                    <option value="@OrderStatus.Paid" selected="@(o.Status == OrderStatus.Paid)">Paid</option>
                                </select>

                                <button type="submit" class="btn btn-sm btn-primary">Save</button>
                            </form>
                        </td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-secondary" asp-action="OrderDetails" asp-route-id="@o.Id">
                                Details
                            </a>
                        </td>
                    </tr>
                }

                @if (Model.Count == 0)
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">
                            No orders found.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>