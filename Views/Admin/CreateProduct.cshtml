@model MiniShop.Models.Product
@using MiniShop.Models

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Create product";
    var categories = ViewBag.Categories as List<Category> ?? new();
}

<div class="row g-3">
    <div class="col-12 col-lg-8">
        <div class="admin-card p-3 p-lg-4">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <div>
                    <div class="h5 mb-1">New product</div>
                    <div class="text-muted small">Fill in the details and upload an image.</div>
                </div>
                <a class="btn btn-outline-secondary" asp-action="Products">
                    <i class="bi bi-arrow-left me-1"></i> Back
                </a>
            </div>

            <form method="post" enctype="multipart/form-data" class="row g-3">
                <div asp-validation-summary="ModelOnly" class="text-danger small"></div>

                <div class="col-12">
                    <label class="form-label">Name</label>
                    <input asp-for="Name" class="form-control" placeholder="Product name" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="col-12 col-md-6">
                    <label class="form-label">Price</label>
                    <input asp-for="Price" class="form-control" placeholder="0" />
                    <span asp-validation-for="Price" class="text-danger small"></span>
                </div>

                <div class="col-12 col-md-6">
                    <label class="form-label">Category</label>
                    <select asp-for="CategoryId" class="form-select">
                        @foreach (var c in categories)
                        {
                            <option value="@c.Id">@c.Name</option>
                        }
                    </select>
                </div>

                <div class="col-12">
                    <label class="form-label">Image</label>
                    <input type="file" class="form-control" name="imageFile" accept=".jpg,.jpeg,.png,.webp" />
                    <div class="form-text">If you don’t upload, a placeholder image will be used.</div>
                </div>

                <div class="col-12 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check2-circle me-1"></i> Save
                    </button>
                    <a class="btn btn-outline-secondary" asp-action="Products">Cancel</a>
                </div>
            </form>
        </div>
    </div>

    <div class="col-12 col-lg-4">
        <div class="admin-card p-3 p-lg-4">
            <div class="h6 mb-2">Tips</div>
            <ul class="small text-muted mb-0">
                <li>Use a clear name for search.</li>
                <li>Recommended image ratio: 4:3 (600×450).</li>
                <li>Price supports decimals.</li>
            </ul>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}